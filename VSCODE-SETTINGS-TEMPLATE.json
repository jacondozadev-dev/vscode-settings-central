// ============================================================
// VSCode Settings Template - Lista para usar
// ============================================================
// INSTRUCCIONES:
// 1. Abre: Cmd+Shift+P → "Preferences: Open Settings (JSON)"
// 2. Copia TODO este archivo
// 3. Pégalo en tu settings.json
// 4. Personaliza según tu stack (ver comentarios)
// ============================================================

{
  // ============== APARIENCIA Y EDITOR ==============
  "editor.fontFamily": "FiraCode Nerd Font",
  "editor.fontLigatures": true,
  "editor.wordWrap": "on",
  "editor.tabSize": 2,
  "editor.insertSpaces": true,

  // ============== SEGURIDAD ==============
  "security.workspace.trust.untrustedFiles": "open",

  // ============== COMPARACIÓN (DIFF) ==============
  "diffEditor.renderSideBySide": true,
  "diffEditor.ignoreTrimWhitespace": true,

  // ============== IMPORTACIONES ==============
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.updateImportsOnFileMove.enabled": "always",

  // ============== ACCIONES AL GUARDAR ==============
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit",
    "source.sortMembers": "explicit"
  },

  // ============== FORMATEADOR POR DEFECTO ==============
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  // ============== TYPESCRIPT ==============
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": false,
    "editor.formatOnType": true,
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "typescript.autoClosingTags": true
  },

  // ============== JAVASCRIPT ==============
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // ============== JSON ==============
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // ============== YAML ==============
  "[yaml]": {
    "diffEditor.ignoreTrimWhitespace": true
  },

  // ============== HTML ==============
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // ============== SCSS ==============
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // ============== FLUTTER / DART (DESCOMENTA SI USAS) ==============
  // "[dart]": {
  //   "editor.formatOnSave": true,
  //   "editor.defaultFormatter": "Dart-Code.dart-code",
  //   "editor.formatOnType": true,
  //   "editor.selectionClipboard": true,
  //   "editor.suggestSelection": "first",
  //   "editor.tabCompletion": "onlySnippets",
  //   "editor.wordBasedSuggestions": false
  // },
  // "dart.lineLength": 100,
  // "flutter.sdkPath": "/opt/flutter",

  // ============== AI Y COPILOT ==============
  "github.copilot.nextEditSuggestions.enabled": true,
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",

  // ============== CHAT Y SESIONES ==============
  "chat.viewSessions.orientation": "stacked",

  // ============== PROXY ==============
  "http.proxyAuthorization": null,

  // ============== AUTO-APPROVE TERMINAL (OPCIONAL) ==============
  // Descomenta si quieres que ciertos comandos se ejecuten sin confirmación
  // "chat.tools.terminal.autoApprove": {
  //   "/^npm install$/": {
  //     "approve": true,
  //     "matchCommandLine": true
  //   },
  //   "/^npm install --legacy-peer-deps$/": {
  //     "approve": true,
  //     "matchCommandLine": true
  //   },
  //   "git restore": true
  // }

  // ============== DEBUGGING XCODE/LLDB (macOS SOLO) ==============
  // Descomenta si trabajas en macOS y usas Xcode/LLDB
  // "lldb.library": "/Applications/Xcode.app/Contents/SharedFrameworks/LLDB.framework/Versions/A/LLDB",
  // "lldb.launch.expressions": "native",
  // "lldb.suppressUpdateNotifications": true
}

// ============================================================
// NOTAS IMPORTANTES:
// ============================================================
// 1. Las líneas con // al principio están comentadas
// 2. Descomenta lo que necesites según tu stack
// 3. Asegúrate de instalar las extensiones recomendadas
// 4. Algunas rutas (Flutter SDK, LLDB) necesitan ajustarse
// 5. Después de cambios, reinicia VSCode (Cmd+Shift+P → Reload Window)
// ============================================================
