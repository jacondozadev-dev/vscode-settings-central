{
  "description": "VSCode Settings por Stack - Extensiones específicas para cada tecnología",
  "lastUpdated": "2026-07-08",

  "web-stack": {
    "description": "TypeScript, Angular, Ionic, Node.js",
    "note": "Incluye todas las configuraciones del archivo base",
    "extensions": [
      "Angular.ng-template",
      "esbenp.prettier-vscode",
      "dbaeumer.vscode-eslint",
      "ms-vscode.vscode-typescript-next"
    ],
    "settings": {
      "typescript.tsdk": "node_modules/typescript/lib",
      "typescript.enablePromptUseWorkspaceTsdk": true,
      "[dart]": {}
    }
  },

  "flutter-stack": {
    "description": "Flutter, Dart",
    "extensions": [
      "Dart-Code.dart-code",
      "Dart-Code.flutter"
    ],
    "settings": {
      "[dart]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "Dart-Code.dart-code",
        "editor.formatOnType": true,
        "editor.selectionClipboard": true,
        "editor.suggestSelection": "first",
        "editor.tabCompletion": "onlySnippets",
        "editor.wordBasedSuggestions": false
      },
      "dart.lineLength": 100,
      "dart.sdkPath": "/opt/flutter/bin/cache/dart-sdk",
      "dart.flutterSdkPath": "/opt/flutter",
      "flutter.sdkPath": "/opt/flutter"
    },
    "notes": [
      "Ajusta las rutas SDK según tu instalación de Flutter",
      "Instala Flutter y Dart extensions desde el marketplace",
      "Combina con settings base para herramientas generales"
    ]
  },

  "debugging": {
    "description": "Configuración para depuración (Xcode LLDB)",
    "settings": {
      "lldb.library": "/Applications/Xcode.app/Contents/SharedFrameworks/LLDB.framework/Versions/A/LLDB",
      "lldb.launch.expressions": "native",
      "lldb.suppressUpdateNotifications": true
    },
    "note": "Úsalo en macOS. En otros SO, usa configuraciones alternativas de depuración"
  },

  "terminal-auto-approve": {
    "description": "Comandos que se ejecutan sin confirmación en el terminal integrado",
    "settings": {
      "chat.tools.terminal.autoApprove": {
        "/^npm install$/": {
          "approve": true,
          "matchCommandLine": true
        },
        "/^npm install --legacy-peer-deps$/": {
          "approve": true,
          "matchCommandLine": true
        },
        "/^npm install eslint@latest @eslint/js@latest typescript-eslint@latest eslint-config-prettier@latest eslint-plugin-prettier@latest globals@latest eslint-plugin-sort-destructure-keys@latest --save-dev$/": {
          "approve": true,
          "matchCommandLine": true
        },
        "/^npm install && npm run lint$/": {
          "approve": true,
          "matchCommandLine": true
        },
        "git restore": true
      }
    }
  }
}
