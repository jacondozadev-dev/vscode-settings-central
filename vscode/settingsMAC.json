{
    "editor.fontFamily": "FiraCode Nerd Font",
    "editor.fontLigatures": true,
    "editor.wordWrap": "on",
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "security.workspace.trust.untrustedFiles": "open",
    "diffEditor.renderSideBySide": true,
    "diffEditor.ignoreTrimWhitespace": true,
    "typescript.updateImportsOnFileMove.enabled": "always",
    "javascript.updateImportsOnFileMove.enabled": "always",
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit",
        "source.organizeImports": "explicit",
        "source.sortMembers": "explicit"
    },
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": false,
        "editor.formatOnType": true,
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.wordSeparators": "`~!@#$%^&*()-=+[{]}\\|;:'\",.<>/?",
        "editor.suggest.insertMode": "replace",
        "editor.suggestSelection": "first",
        "typescript.autoClosingTags": true
    },
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[yaml]": {
        "diffEditor.ignoreTrimWhitespace": true
    },
    "[html]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[scss]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "chat.viewSessions.orientation": "stacked",
    "github.copilot.nextEditSuggestions.enabled": true,
    "gitlens.ai.model": "vscode",
    "typescript.tsdk": "node_modules/typescript/lib",
    "typescript.enablePromptUseWorkspaceTsdk": true,
    "lldb.library": "/Applications/Xcode.app/Contents/SharedFrameworks/LLDB.framework/Versions/A/LLDB",
    "lldb.launch.expressions": "native",
    "lldb.suppressUpdateNotifications": true,
    "http.proxyAuthorization": null,
    "settingsSync.ignoredExtensions": [],
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "chat.tools.terminal.autoApprove": {
        "/^npm install$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^npm install --legacy-peer-deps$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^npm install eslint@latest @eslint/js@latest typescript-eslint@latest eslint-config-prettier@latest eslint-plugin-prettier@latest globals@latest eslint-plugin-sort-destructure-keys@latest --save-dev$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^npm install && npm run lint$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "git restore": true,
        "/^node -e \"console\\.log\\(require\\('child_process'\\)\\.spawnSync\\('npm',\\['run','start','qa','web'\\],\\{shell:false,stdio:'pipe'\\}\\)\\.stderr\\.toString\\(\\)\\)\"$/": {
            "approve": true,
            "matchCommandLine": true
        }
    }
}